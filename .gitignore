# PM320 repo — 직접 서빙 전환 (homepage repo에서 sync된 정적 자산)
# 라이브 fetch 대상(data/* 하위 JSON)만 추적, DB·백업·디버그는 제외.

# DB 원본·백업 (라이브는 정적 JSON만 fetch — DB는 cron worktree 전용)
data/stocks.db
data/stocks.db-wal
data/stocks.db-shm
data/stocks.db.bak*
data/stocks.db.backup_*
data/themes.db
data/themes.db-shm
data/themes.db-wal
data/minute_bars.db
data/minutes.db
data/minutes.db-wal
data/minutes.db-shm
data/minutes_nxt.db
data/minutes_nxt.db-wal
data/minutes_nxt.db-shm
data/.backup-*
data/backups/

# 카페 스크레이퍼 작업 DB (로컬 런타임 전용 — 라이브는 산출 JSON만 서빙)
scripts/cafe-scraper/cafe.db
scripts/cafe-scraper/cafe.db-wal
scripts/cafe-scraper/cafe.db-shm

# 카페 디버그 산출물
data/cafe/debug_*.html
data/cafe/debug/
data/cafe/debug_*.png

# 시크릿 env (S5 자립화 DOC-20260707-REQ-001: 로컬 런타임 전용 — 절대 커밋 금지)
# scripts/news_pipeline/.env: S2 이관 시 tracked 노출(DART_API_KEY) → 2026-07-07 git rm --cached 제거 완료.
# 루트 .env(KIWOOM/KAKAO/GOOGLE) + 모든 하위 .env 는 아래 규칙으로 커밋 차단. 로컬 파일은 런타임 유지.
.env
**/.env
!*.env.example

# OS·에디터
.DS_Store
*.swp

# 전환 준비 스크립트 로그
scripts/*.log

# S5b-2 이관 시 딸려온 스크래퍼 로그 (런타임 산출·커밋 금지)
scripts/cafe-scraper/logs/
scripts/kiwoom-scraper/logs/

# ── Option A (2026-07-07): 파이프라인 비공개 — 서빙만 public ────────────────
# pm320 레포는 public(GitHub Pages). 파이프라인 로직·시크릿·크레덴셜은 노출 금지.
# 로컬 파일은 launchd 런타임 SoT로 유지, git 추적만 제거(HEAD untrack).
# 서빙(index/pm320/news .html·js/·data/·og/·sw.js·CNAME 등)은 계속 추적.
scripts/
launchd/
records/
data/rsi/
